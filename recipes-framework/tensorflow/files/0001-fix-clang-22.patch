diff --git a/third_party/com_google_highway/0001-mark-avx10.2-broken-prior-to-gcc-15.2-clang-20.-Fixe.patch b/third_party/com_google_highway/0001-mark-avx10.2-broken-prior-to-gcc-15.2-clang-20.-Fixe.patch
